---
const { title } = Astro.props;
---

<html>
  <head>
    <meta charset="UTF-8" />
    <title>{title}</title>
    <link rel="shortcut icon" href="favicon.ico" type="image/x-icon">
  </head>
  <body>
    <header>
      <div class="logo">
        <img src="/logo.png" alt="Hattrick Stadium Simulator Logo" />
      </div>
      <h1>HT Lab</h1>
    </header>

    <slot />
  </body>
</html>